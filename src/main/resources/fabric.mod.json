{
  "schemaVersion": 1,
  "id": "mcsreasymode",
  "version": "${version}",
  "name": "MCSR Easy Mode",
  "description": "minecraft speedrunning if its all sunshine and rainbows",
  "authors": [
    "dota1g"
  ],
  "contact": {},
  "license": "MIT",
  "environment": "*",
  "entrypoints": {
    "preLaunch": [
      "me.dota1g.mcsreasymode.McsreasymodePreLaunch"
    ],
    "client": [
      "me.dota1g.mcsreasymode.client.McsreasymodeClient"
    ],
    "main": [
      "me.dota1g.mcsreasymode.Mcsreasymode"
    ]
  },
  "mixins": [
    "mcsreasymode.mixins.json"
  ],
  "accessWidener": "mcsreasymode.accesswidener",
  "icon": "assets/mcsreasymode/icon.png",
  "custom": {
    "speedrunapi": {
      "config": "me.dota1g.mcsreasymode.McsreasymodeConfig"
    }
  },
  "depends": {
    "fabricloader": ">=${loader_version}",
    "minecraft": "${minecraft_version}",
    "fabric-resource-loader-v0": ">=0.2.6",
    "speedrunapi": ">=1.2"
  },
  "breaks": {
    "mcsrranked": "*",
    "mcsr-fairplay-public": "*"
  }
}
